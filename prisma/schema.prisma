generator client {
  provider = "prisma-client"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  clerkId       String    @unique
  email         String    @unique
  name          String
  role          UserRole  @default(BOTH)
  skills        String[]
  interests     String[]
  location      String?
  bio           String?
  trustScore    Int       @default(0)
  badges        Badge[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  requests      Request[]
  helpOffers    HelpOffer[]
  messages      Message[] @relation("SentMessages")
  notifications Notification[]
}

model Request {
  id            String      @id @default(cuid())
  title         String
  description   String
  category      String
  tags          String[]
  urgency       UrgencyLevel @default(MEDIUM)
  status        RequestStatus @default(OPEN)
  aiSummary     String?
  userId        String
  user          User        @relation(fields: [userId], references: [id])
  helperId      String?
  solvedAt      DateTime?
  helpOffers    HelpOffer[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model HelpOffer {
  id          String   @id @default(cuid())
  message     String
  status      String   @default("PENDING")
  requestId   String
  request     Request  @relation(fields: [requestId], references: [id])
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  createdAt   DateTime @default(now())
}

model Message {
  id          String   @id @default(cuid())
  content     String
  senderId    String
  sender      User     @relation("SentMessages", fields: [senderId], references: [id])
  receiverId  String
  requestId   String?
  read        Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model Notification {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  title       String
  message     String
  type        String
  read        Boolean  @default(false)
  createdAt   DateTime @default(now())
}

enum UserRole {
  NEED_HELP
  CAN_HELP
  BOTH
}

enum UrgencyLevel {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum RequestStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum Badge {
  HELPER
  PROBLEM_SOLVER
  TRUSTED
  COMMUNITY_LEADER
  TOP_CONTRIBUTOR
}
